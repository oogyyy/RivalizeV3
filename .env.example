# =============================================================
# RIVALIZE — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these in the Vercel dashboard under:
#   Project → Settings → Environment Variables
# =============================================================

# -------------------------------------------------------------
# SUPABASE  (required — auth + database only)
# Get these from: Supabase → Project Settings → API
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------------
# CLOUDFLARE R2  (required — file storage for .dem uploads)
#
# Setup steps:
#   1. Go to Cloudflare Dashboard → R2 → Create Bucket
#      Name: rivalize-demos  (or any name, set below)
#
#   2. On the bucket page → Settings → CORS Policy, paste:
#      [{"AllowedOrigins":["https://your-domain.com","http://localhost:3000"],
#        "AllowedMethods":["PUT"],
#        "AllowedHeaders":["Content-Type"],
#        "MaxAgeSeconds":3600}]
#
#   3. Enable "Public access" on the bucket (or add a custom domain)
#      Copy the public URL shown (e.g. https://pub-xxx.r2.dev)
#
#   4. Cloudflare Dashboard → R2 → Manage R2 API Tokens
#      → Create API Token with "Object Read & Write" on your bucket
#      Copy the Access Key ID and Secret Access Key shown once.
#
#   5. Your Account ID is shown in the R2 overview page URL:
#      dash.cloudflare.com/<ACCOUNT_ID>/r2/overview
# -------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=rivalize-demos
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL for the bucket — no trailing slash
# Use the r2.dev subdomain OR your custom domain if configured
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# -------------------------------------------------------------
# AI PROVIDER  (required for AI coach, briefs, reports, playbooks)
# Default provider is Groq (https://console.groq.com) running
# llama-3.3-70b-versatile.
# -------------------------------------------------------------
GROQ_API_KEY=gsk_...

# Optional: point all AI features at any OpenAI-compatible provider
# instead of the Groq default (these take precedence over GROQ_API_KEY).
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# -------------------------------------------------------------
# STEAM LINKING  (no secret required — uses OpenID)
# No API key needed for basic linking; Steam ID is extracted
# from the OpenID claimed_id URL after validation.
# Optional: add STEAM_API_KEY to fetch Steam profile info.
# STEAM_API_KEY=your-steam-web-api-key
# -------------------------------------------------------------

# -------------------------------------------------------------
# FACEIT LINKING  (OAuth 2.0 PKCE)
# 1. Go to https://developers.faceit.com → Create App
# 2. Set the redirect URI to: https://your-domain.com/api/auth/faceit/callback
# 3. Copy the Client ID and Client Secret below
# -------------------------------------------------------------
FACEIT_CLIENT_ID=your-faceit-client-id
FACEIT_CLIENT_SECRET=your-faceit-client-secret

# -------------------------------------------------------------
# PANDASCORE  (optional — live pro match results in Pro Match Library)
# Free tier covers schedules & results: https://www.pandascore.co
# Sign up → dashboard → copy your API token below.
# Without this key the Pro Match Library falls back to a curated list.
# -------------------------------------------------------------
# PANDASCORE_API_KEY=your-pandascore-token

# -------------------------------------------------------------
# GO PARSER SERVICE  (required — CS2 demo parsing)
# Deploy go-parser/ as a separate Railway service, then set this
# to the internal Railway URL (fast, no egress cost) or public URL.
# Example: https://go-parser.up.railway.app
# -------------------------------------------------------------
PARSER_URL=http://localhost:8080

# Optional: Discord webhook for worker ops alerts (parser health/queue stalls).
# When set, the worker posts here if the Go parser goes down while demos wait,
# and again when it recovers. Without it, alerts go to the worker logs only.
# OPS_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# The Go parser needs direct access to Supabase (for the lightweight
# status='parsed' update) and to R2 credentials are NOT needed —
# the worker passes presigned URLs instead.
#
# Set these in the Railway environment for the go-parser service:
#
#   SUPABASE_URL              same as NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY same as SUPABASE_SERVICE_ROLE_KEY
#   GOGC=75                   (already set in Dockerfile — Railway Pro default)
#   GOMEMLIMIT=1932735283     (already set in Dockerfile — 1.8 GB cap for 2 GB Railway Pro replica)

# -------------------------------------------------------------
# STRIPE  (required for billing & subscription features)
# 1. Sign up at https://stripe.com
# 2. Dashboard → Developers → API Keys → copy Secret Key
# 3. Create two Products (Pro $19/mo, Team $49/mo) and copy their Price IDs
# 4. Dashboard → Developers → Webhooks → Add endpoint:
#      URL: https://your-domain.com/api/webhooks/stripe
#      Events: checkout.session.completed, customer.subscription.updated,
#              customer.subscription.deleted, invoice.payment_failed
#    Copy the Signing Secret shown after saving.
# Use test-mode keys (sk_test_...) for local dev, live keys in production.
# -------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -------------------------------------------------------------
# APP
# In production: set this to your Vercel-provided domain or
# custom domain, e.g. https://rivalize.pro
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
