# =============================================================
# RIVALIZE — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these in the Vercel dashboard under:
#   Project → Settings → Environment Variables
# =============================================================

# -------------------------------------------------------------
# SUPABASE  (required — auth + database only)
# Get these from: Supabase → Project Settings → API
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------------
# CLOUDFLARE R2  (required — file storage for .dem uploads)
#
# Setup steps:
#   1. Go to Cloudflare Dashboard → R2 → Create Bucket
#      Name: rivalize-demos  (or any name, set below)
#
#   2. On the bucket page → Settings → CORS Policy, paste:
#      [{"AllowedOrigins":["https://your-domain.com","http://localhost:3000"],
#        "AllowedMethods":["PUT"],
#        "AllowedHeaders":["Content-Type"],
#        "MaxAgeSeconds":3600}]
#
#   3. Enable "Public access" on the bucket (or add a custom domain)
#      Copy the public URL shown (e.g. https://pub-xxx.r2.dev)
#
#   4. Cloudflare Dashboard → R2 → Manage R2 API Tokens
#      → Create API Token with "Object Read & Write" on your bucket
#      Copy the Access Key ID and Secret Access Key shown once.
#
#   5. Your Account ID is shown in the R2 overview page URL:
#      dash.cloudflare.com/<ACCOUNT_ID>/r2/overview
# -------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=rivalize-demos
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL for the bucket — no trailing slash
# Use the r2.dev subdomain OR your custom domain if configured
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# -------------------------------------------------------------
# AI PROVIDER  (choose one or more)
# -------------------------------------------------------------
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# xAI / Grok — https://console.x.ai
# XAI_API_KEY=xai-...

# Anthropic / Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------------
# STEAM LINKING  (no secret required — uses OpenID)
# No API key needed for basic linking; Steam ID is extracted
# from the OpenID claimed_id URL after validation.
# Optional: add STEAM_API_KEY to fetch Steam profile info.
# STEAM_API_KEY=your-steam-web-api-key
# -------------------------------------------------------------

# -------------------------------------------------------------
# FACEIT LINKING  (OAuth 2.0 PKCE)
# 1. Go to https://developers.faceit.com → Create App
# 2. Set the redirect URI to: https://your-domain.com/api/auth/faceit/callback
# 3. Copy the Client ID and Client Secret below
# -------------------------------------------------------------
FACEIT_CLIENT_ID=your-faceit-client-id
FACEIT_CLIENT_SECRET=your-faceit-client-secret

# -------------------------------------------------------------
# GO PARSER SERVICE  (required — CS2 demo parsing)
# Deploy go-parser/ as a separate Railway service, then set this
# to the internal Railway URL (fast, no egress cost) or public URL.
# Example: https://go-parser.up.railway.app
# -------------------------------------------------------------
PARSER_URL=http://localhost:8080

# -------------------------------------------------------------
# APP
# In production: set this to your Vercel-provided domain or
# custom domain, e.g. https://rivalize.pro
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
