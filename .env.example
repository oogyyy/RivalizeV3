# =============================================================
# RIVALIZE — Environment Variables
# Copy this file to .env.local for local development.
# Set all of these in the Railway dashboard under:
#   Project → Service → Variables
# =============================================================

# -------------------------------------------------------------
# SUPABASE  (required)
# Get these from: Supabase → Project Settings → API
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------------
# AI PROVIDER  (choose one or more)
# -------------------------------------------------------------
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# xAI / Grok — https://console.x.ai
# XAI_API_KEY=xai-...

# Anthropic / Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------------
# APP
# In Railway: set this to your Railway-provided domain or custom
# domain, e.g. https://rivalize-production.up.railway.app
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------
# RAILWAY NOTES
# -------------------------------------------------------------
# • NEXT_PUBLIC_* variables are baked into the client bundle at
#   build time. Set them BEFORE deploying, not after.
#
# • Railway passes all Variables to Docker build args
#   automatically — no extra configuration needed.
#
# • If you add a Railway Postgres service later, reference it as:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# • Recommended Railway service settings:
#     Restart policy : ON_FAILURE (max 3 retries)
#     Health check   : /api/health  (timeout 30 s)
#     Region         : us-west2 (closest to Supabase us-west-1)
# -------------------------------------------------------------
